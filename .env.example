# Copy to .env and fill in keys. Keys for sources you don't use can stay blank;
# rich_iocs will skip those sources with a warning.

# VirusTotal v3 — https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# abuse.ch (shared across Malware Bazaar, URLhaus, ThreatFox) — https://auth.abuse.ch/
ABUSECH_AUTH_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=

# GreyNoise community (optional; the community endpoint also works unauthenticated
# but auth raises rate limits). https://viz.greynoise.io/account/
GREYNOISE_API_KEY=
